{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "Uptime",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [{ "expr": "corridorkey_uptime_seconds", "legendFormat": "uptime" }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      }
    },
    {
      "type": "stat",
      "title": "Jobs Running",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [{ "expr": "corridorkey_jobs_running", "legendFormat": "running" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Queue Depth",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [{ "expr": "corridorkey_jobs_queued", "legendFormat": "queued" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Nodes Online",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [{ "expr": "corridorkey_nodes_online", "legendFormat": "online" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Completed/hr",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [{ "expr": "corridorkey_jobs_completed_last_hour", "legendFormat": "completed" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      }
    },
    {
      "type": "stat",
      "title": "Disk Free",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "targets": [{ "expr": "corridorkey_disk_free_gb", "legendFormat": "free" }],
      "fieldConfig": {
        "defaults": {
          "unit": "decgbytes",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "green", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Job Queue Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "corridorkey_jobs_running", "legendFormat": "running" },
        { "expr": "corridorkey_jobs_queued", "legendFormat": "queued" }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 } } }
    },
    {
      "type": "timeseries",
      "title": "Job Completions & Failures",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "rate(corridorkey_jobs_completed_total[5m]) * 60", "legendFormat": "completed/min" },
        { "expr": "rate(corridorkey_jobs_failed_total[5m]) * 60", "legendFormat": "failed/min" }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "failed/min" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "type": "timeseries",
      "title": "Node Status Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "expr": "corridorkey_nodes_online", "legendFormat": "online" },
        { "expr": "corridorkey_nodes_busy", "legendFormat": "busy" },
        { "expr": "corridorkey_nodes_offline", "legendFormat": "offline" }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "offline" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "busy" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "type": "timeseries",
      "title": "GPU Credits (per-org)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "expr": "corridorkey_gpu_credits_contributed_seconds / 3600", "legendFormat": "contributed {{ org }}" },
        { "expr": "corridorkey_gpu_credits_consumed_seconds / 3600", "legendFormat": "consumed {{ org }}" }
      ],
      "fieldConfig": { "defaults": { "unit": "h", "custom": { "fillOpacity": 5 } } }
    },
    {
      "type": "timeseries",
      "title": "WebSocket Connections",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 20 },
      "targets": [
        { "expr": "corridorkey_ws_connections", "legendFormat": "connections" }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 15 } } }
    },
    {
      "type": "timeseries",
      "title": "API Requests",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 20 },
      "targets": [
        { "expr": "rate(corridorkey_api_requests_total[5m]) * 60", "legendFormat": "req/min" }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 15 } } }
    },
    {
      "type": "timeseries",
      "title": "Disk Space",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 20 },
      "targets": [
        { "expr": "corridorkey_disk_total_gb", "legendFormat": "total" },
        { "expr": "corridorkey_disk_free_gb", "legendFormat": "free" }
      ],
      "fieldConfig": { "defaults": { "unit": "decgbytes", "custom": { "fillOpacity": 10 } } }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["corridorkey"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "CorridorKey — Platform Overview",
  "uid": "corridorkey-platform",
  "version": 1
}
