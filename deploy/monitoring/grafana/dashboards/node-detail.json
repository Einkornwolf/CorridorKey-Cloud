{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "Reputation Score",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "corridorkey_node_reputation{node=~\"$node\"}", "legendFormat": "{{ node }}" }],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 40 },
              { "color": "green", "value": 70 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Success Rate",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "corridorkey_node_success_rate{node=~\"$node\"}", "legendFormat": "{{ node }}" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "CPU Usage",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "corridorkey_node_cpu_percent{node=~\"$node\"}", "legendFormat": "{{ node }}" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "RAM Used",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "corridorkey_node_ram_used_gb{node=~\"$node\"}", "legendFormat": "{{ node }}" }],
      "fieldConfig": { "defaults": { "unit": "decgbytes", "thresholds": { "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "type": "timeseries",
      "title": "VRAM Usage Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "corridorkey_node_vram_total_gb{node=~\"$node\"}", "legendFormat": "total {{ gpu }}" },
        { "expr": "corridorkey_node_vram_used_gb{node=~\"$node\"}", "legendFormat": "used {{ gpu }}" }
      ],
      "fieldConfig": { "defaults": { "unit": "decgbytes", "custom": { "fillOpacity": 10 } } }
    },
    {
      "type": "timeseries",
      "title": "CPU & RAM Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "corridorkey_node_cpu_percent{node=~\"$node\"}", "legendFormat": "CPU % {{ node }}" },
        { "expr": "corridorkey_node_ram_used_gb{node=~\"$node\"}", "legendFormat": "RAM GB {{ node }}" }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 } } }
    },
    {
      "type": "timeseries",
      "title": "Success Rate Over Time",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "targets": [
        { "expr": "corridorkey_node_success_rate{node=~\"$node\"}", "legendFormat": "{{ node }}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "custom": { "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["corridorkey", "nodes"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(corridorkey_node_cpu_percent, node)",
        "includeAll": true,
        "multi": true,
        "name": "node",
        "query": "label_values(corridorkey_node_cpu_percent, node)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "CorridorKey — Node Detail",
  "uid": "corridorkey-nodes",
  "version": 1
}
